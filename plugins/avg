const { cmd } = require('../command');
const axios = require("axios");
const config = require('../config');

const API_BASE = "https://vajira-official-apis.vercel.app/api";
const API_KEY = "vajira-VajiraOfficial2003";

// Seedr Credentials
const seedrConfig = {
    email: "drkamran8309@gmail.com",
    password: "kamram00#"
};

cmd({
    pattern: "sublk",
    desc: "Search and download movies via SubLK and Seedr safely.",
    category: "download",
    react: "🎬",
    use: ".sublk [movie name]",
    filename: __filename
},
async (conn, mek, m, { from, q, reply }) => {
    try {
        // 1. Immediate validation check so the bot responds even without a movie name
        if (!q || typeof q !== 'string' || !q.trim()) {
            return reply("❌ *Format Galat Hai!*\n\n*Usage:* `.sublk [Movie Name]`\n\n*Example:* `.sublk Avatar`");
        }

        // 2. Dynamic dependency injector to prevent silent boot crashes
        let Seedr;
        try {
            Seedr = require('seedr');
        } catch (dependencyError) {
            return reply("❌ *Dependency Missing!*\n\nApne terminal/VPS me yeh command run karein:\n```npm install seedr
```\n\nAur phir bot ko restart (`npm start`) karein!");
        }
        
        await conn.sendMessage(from, { react: { text: "🔍", key: mek.key } });

        const { data: searchRes } = await axios.get(`${API_BASE}/sublk?apikey=${API_KEY}&q=${encodeURIComponent(q.trim())}`);
        if (!searchRes.status || !searchRes.data || !searchRes.data.length) {
            return reply("❌ No results found for your search query.");
        }

        const list = searchRes.data.slice(0, 10);
        let text = `🎬 *ꜰʟᴇxᴀ ᴍᴏᴠɪᴇ ꜱᴇᴀʀᴄʜ*\n\n`;
        list.forEach((m, i) => { text += `*${i + 1}.* ${m.title}\n`; });
        text += `\n📥 *Reply with the number to select*`;

        const sent = await conn.sendMessage(from, { text }, { quoted: mek });

        // --- FIRST LISTENER: TO SELECT MOVIE ---
        const handler = async (up) => {
            try {
                const incoming = up.messages?.[0];
                if (!incoming?.message || incoming.key.remoteJid !== from) return;

                const textContent = incoming.message.conversation || incoming.message.extendedTextMessage?.text || "";
                const index = parseInt(textContent.trim());
                
                if (isNaN(index) || !list[index - 1]) return;

                conn.ev.off("messages.upsert", handler);
                const selected = list[index - 1];

                await conn.sendMessage(from, { react: { text: "⏳", key: incoming.key } });

                const { data: detailRes } = await axios.get(`${API_BASE}/sublkdl?apikey=${API_KEY}&url=${encodeURIComponent(selected.url)}`);
                const movie = detailRes.data;

                if (!movie || !movie.torrents?.length) return reply("❌ No torrents found for this movie.");

                let qText = `🎬 *${movie.title.toUpperCase()}*\n\n` +
                            `📅 *Date:* ${movie.date || 'N/A'}\n` +
                            `⭐ *IMDb:* ${movie.imdbRate || 'N/A'}\n` +
                            `🎭 *Genres:* ${Array.isArray(movie.genres) ? movie.genres.join(", ") : 'N/A'}\n\n` +
                            `📥 *Select Quality to Download:*\n`;
                
                movie.torrents.forEach((t, i) => { qText += `*${i + 1}.* ${t.quality} (${t.size})\n`; });
                qText += `\n> *${config.BOT_NAME || 'KAMRAN-MD'}*`;

                const infoMsg = await conn.sendMessage(from, { image: { url: movie.image }, caption: qText }, { quoted: incoming });

                // --- SECOND LISTENER: TO SELECT QUALITY ---
                const dlHandler = async (up2) => {
                    try {
                        const incoming2 = up2.messages?.[0];
                        if (!incoming2?.message || incoming2.key.remoteJid !== from) return;

                        const dlTextContent = incoming2.message.conversation || incoming2.message.extendedTextMessage?.text || "";
                        const choice = parseInt(dlTextContent.trim());
                        
                        if (isNaN(choice) || !movie.torrents[choice - 1]) return;

                        conn.ev.off("messages.upsert", dlHandler);
                        const torrent = movie.torrents[choice - 1];
                        
                        await conn.sendMessage(from, { react: { text: "⏳", key: incoming2.key } });
                        await reply("📥 *Adding torrent to Seedr cloud... Please wait.*");

                        const seedr = new Seedr();
                        await seedr.login(seedrConfig.email, seedrConfig.password);

                        const hashMatch = torrent.url.match(/([a-fA-F0-9]{40})/);
                        if (!hashMatch) throw new Error("Could not extract torrent hash info.");

                        const magnet = `magnet:?xt=urn:btih:${hashMatch[1]}&dn=${encodeURIComponent(movie.title)}`;
                        await seedr.addMagnet(magnet);

                        await new Promise(r => setTimeout(r, 6000));

                        let fileInfo = null;
                        let folderId = null;

                        for (let i = 0; i < 20; i++) {
                            const files = await seedr.getVideos();
                            if (files && files[0] && files[0].length > 0) {
                                folderId = files[0][0].fid;
                                fileInfo = await seedr.getFile(files[0][0].id);
                                break;
                            }
                            await new Promise(r => setTimeout(r, 4000));
                        }

                        if (!fileInfo || !fileInfo.url) {
                            throw new Error("Seedr processing timeout. Ensure file size is under 2GB.");
                        }

                        await reply("🚀 *Downloading from Seedr and uploading to WhatsApp...*");

                        await conn.sendMessage(from, {
                            document: { url: fileInfo.url },
                            mimetype: "video/mp4",
                            fileName: `${movie.title} [${torrent.quality}].mp4`,
                            caption: `🎬 *${movie.title}*\n📦 *Quality:* ${torrent.quality}\n\n> *${config.BOT_NAME || 'KAMRAN-MD'}*`
                        }, { quoted: incoming2 });

                        if (folderId) await seedr.deleteFolder(folderId);

                    } catch (dlErr) {
                        reply("❌ Seedr Error: " + dlErr.message);
                        conn.ev.off("messages.upsert", dlHandler);
                    }
                };

                conn.ev.on("messages.upsert", dlHandler);
                setTimeout(() => conn.ev.off("messages.upsert", dlHandler), 300000);

            } catch (hErr) {
                console.error(hErr);
                conn.ev.off("messages.upsert", handler);
            }
        };

        conn.ev.on("messages.upsert", handler);
        setTimeout(() => conn.ev.off("messages.upsert", handler), 300000);

    } catch (e) {
        reply("❌ System Error: " + e.message);
    }
});
